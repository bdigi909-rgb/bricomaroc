# ============================================================
# BricoMaroc — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=VOTRE_SERVICE_ROLE_KEY

# Paiement CMI Maroc
CMI_MERCHANT_ID=VOTRE_MERCHANT_ID
CMI_SECRET_KEY=VOTRE_SECRET_KEY
CMI_CALLBACK_URL=https://bricomaroc.ma/api/payment/cmi/callback

# Stripe (cartes internationales)
STRIPE_PUBLIC_KEY=pk_live_VOTRE_CLE_PUBLIQUE
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_SECRETE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_WEBHOOK_SECRET

# SMS - Infobip Maroc
INFOBIP_API_KEY=VOTRE_API_KEY
INFOBIP_BASE_URL=https://VOTRE_INSTANCE.api.infobip.com
INFOBIP_FROM=BricoMaroc

# WhatsApp Business API
WHATSAPP_TOKEN=VOTRE_WHATSAPP_TOKEN
WHATSAPP_PHONE_ID=VOTRE_PHONE_ID

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=VOTRE_GOOGLE_MAPS_KEY

# OpenAI (IA matching)
OPENAI_API_KEY=sk-VOTRE_OPENAI_KEY

# Firebase (notifications push)
NEXT_PUBLIC_FIREBASE_API_KEY=VOTRE_FIREBASE_KEY
NEXT_PUBLIC_FIREBASE_PROJECT_ID=VOTRE_PROJECT_ID
FIREBASE_SERVER_KEY=VOTRE_SERVER_KEY

# App
NEXT_PUBLIC_APP_URL=https://bricomaroc.ma
NEXTAUTH_SECRET=VOTRE_SECRET_ALEATOIRE_LONG
